<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#0A0A0B"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Settings"
            android:textSize="22sp"
            android:textColor="#F1F1F1"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v0.2.0"
            android:textSize="12sp"
            android:textColor="#A1A1AA"
            android:layout_marginEnd="8dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_rounded"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textSize="13sp"
            android:textColor="#3B82F6"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <View
                android:id="@+id/indicatorA11y"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_status_dot_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  a11y"
                android:textSize="13sp"
                android:textColor="#A1A1AA" />

            <TextView
                android:id="@+id/tvA11yStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="active"
                android:textSize="13sp"
                android:textColor="#10B981"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <View
                android:id="@+id/indicatorServer"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_status_dot_green" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="  server"
                android:textSize="13sp"
                android:textColor="#A1A1AA" />

            <TextView
                android:id="@+id/tvServerStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8765"
                android:textSize="13sp"
                android:textColor="#10B981"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnToggleMainServer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="32dp"
                android:minWidth="64dp"
                android:text="STOP"
                android:textSize="11sp"
                android:textColor="#F1F1F1"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:backgroundTint="#2D2D30"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textAllCaps="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <View
                android:id="@+id/indicatorRelay"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_status_dot_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  relay"
                android:textSize="13sp"
                android:textColor="#A1A1AA" />

            <TextView
                android:id="@+id/tvRelayAddr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="13sp"
                android:textColor="#10B981"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/indicatorAuth"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_status_dot_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  auth"
                android:textSize="13sp"
                android:textColor="#A1A1AA" />

            <TextView
                android:id="@+id/tvAuthCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="------"
                android:textSize="13sp"
                android:textColor="#10B981"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/indicatorAgent"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_status_dot_grey" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  termux"
                android:textSize="13sp"
                android:textColor="#A1A1AA" />

            <TextView
                android:id="@+id/tvAgentStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="offline"
                android:textSize="13sp"
                android:textColor="#A1A1AA"
                android:layout_marginStart="4dp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_rounded"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Permissions"
            android:textSize="13sp"
            android:textColor="#3B82F6"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Enable Accessibility Service"
                android:textSize="13sp"
                android:textColor="#A1A1AA" />

            <Switch
                android:id="@+id/switchAccessibility"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:track="@drawable/bg_switch_track"
                android:thumb="@drawable/bg_switch_thumb" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Enable Status Overlay"
                android:textSize="13sp"
                android:textColor="#A1A1AA" />

            <Switch
                android:id="@+id/switchOverlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:track="@drawable/bg_switch_track"
                android:thumb="@drawable/bg_switch_thumb" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Screen Recording Granted"
                android:textSize="13sp"
                android:textColor="#A1A1AA" />

            <Switch
                android:id="@+id/switchScreenRecord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:track="@drawable/bg_switch_track"
                android:thumb="@drawable/bg_switch_thumb" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_rounded"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pairing Code"
            android:textSize="13sp"
            android:textColor="#3B82F6"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvPairingCode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="------"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="#3B82F6"
                android:letterSpacing="0.3" />

            <Button
                android:id="@+id/btnRegenerate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="36dp"
                android:text="Refresh"
                android:textSize="12sp"
                android:textColor="#F1F1F1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:backgroundTint="#2D2D30"
                android:textAllCaps="false" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap code to copy. Send to Aeva, connect my phone, code is..."
            android:textSize="11sp"
            android:textColor="#A1A1AA" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_rounded"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LLM Inference"
            android:textSize="13sp"
            android:textColor="#3B82F6"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <View
                android:id="@+id/indicatorLlmServer"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_status_dot_grey" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  server"
                android:textSize="13sp"
                android:textColor="#A1A1AA" />

            <TextView
                android:id="@+id/tvLlmServerStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="stopped"
                android:textSize="13sp"
                android:textColor="#A1A1AA"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <View
                android:id="@+id/indicatorModel"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_status_dot_grey" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  model"
                android:textSize="13sp"
                android:textColor="#A1A1AA" />

            <TextView
                android:id="@+id/tvModelStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="not loaded"
                android:textSize="13sp"
                android:textColor="#A1A1AA"
                android:layout_marginStart="4dp"
                android:ellipsize="middle"
                android:singleLine="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">
            <TextView
                android:id="@+id/tvModelName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gemma-4-E2B-it"
                android:textSize="11sp"
                android:textColor="#F1F1F1"
                
                android:paddingHorizontal="4dp"
                android:layout_marginBottom="4dp" />
            <ProgressBar
                android:id="@+id/pbDownload"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:progressDrawable="@android:drawable/progress_horizontal"
                android:visibility="gone" />
            <TextView
                android:id="@+id/tvDownloadProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="10sp"
                android:textColor="#A1A1AA"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnReloadModel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="40dp"
                android:layout_weight="1"
                android:text="Download"
                android:textSize="12sp"
                android:textColor="#F1F1F1"
                android:backgroundTint="#2D2D30"
                android:layout_marginEnd="4dp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnToggleLlmServer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="40dp"
                android:layout_weight="1"
                android:text="Start Server"
                android:textSize="12sp"
                android:textColor="#F1F1F1"
                android:backgroundTint="#2D2D30"
                android:layout_marginStart="4dp"
                android:textAllCaps="false" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_rounded"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connect to Server"
            android:textSize="13sp"
            android:textColor="#3B82F6"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etServerUrl"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="server-ip:8766"
            android:inputType="textUri"
            android:textSize="15sp"
            android:textColor="#F1F1F1"
            android:textColorHint="#444444"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@drawable/bg_input_dark"
            android:layout_marginBottom="8dp"
            android:singleLine="true" />

        <TextView
            android:id="@+id/tvRelayStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Not connected"
            android:textSize="12sp"
            android:textColor="#A1A1AA"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:text="CONNECT"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3B82F6"
            android:textAllCaps="false" />
    </LinearLayout>

    <Button
        android:id="@+id/btnDisconnect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:text="⏏ DISCONNECT"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#F1F1F1"
        android:backgroundTint="#2D2D30"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        android:textAllCaps="false" />

    <TextView
        android:id="@+id/tvAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="11sp"
        android:textColor="#A1A1AA"
        android:gravity="center_horizontal" />

</LinearLayout>
</ScrollView>
