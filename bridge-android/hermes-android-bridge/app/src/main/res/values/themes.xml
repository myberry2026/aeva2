<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HermesBridge" parent="android:Theme.DeviceDefault.NoActionBar">
    </style>

    <style name="Theme.HermesBridge.Day" parent="android:Theme.DeviceDefault.Light.NoActionBar">
        <item name="android:windowBackground">@color/daylight_background</item>
        <item name="color_background">@color/daylight_background</item>
        <item name="color_surface">@color/daylight_surface</item>
        <item name="color_border">@color/daylight_border</item>
        <item name="color_text_primary">@color/daylight_text_primary</item>
        <item name="color_text_secondary">@color/daylight_text_secondary</item>
        <item name="color_accent">@color/daylight_accent</item>
        <item name="color_success">@color/daylight_success</item>
        <item name="color_card_bg">@color/daylight_card_bg</item>
        <item name="color_input_bg">@color/daylight_input_bg</item>
    </style>

    <style name="Theme.HermesBridge.Night" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@color/midnight_background</item>
        <item name="color_background">@color/midnight_background</item>
        <item name="color_surface">@color/midnight_surface</item>
        <item name="color_border">@color/midnight_border</item>
        <item name="color_text_primary">@color/midnight_text_primary</item>
        <item name="color_text_secondary">@color/midnight_text_secondary</item>
        <item name="color_accent">@color/midnight_accent</item>
        <item name="color_success">@color/midnight_success</item>
        <item name="color_card_bg">@color/midnight_card_bg</item>
        <item name="color_input_bg">@color/midnight_input_bg</item>
    </style>
</resources>
